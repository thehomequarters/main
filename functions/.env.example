# Stripe Price IDs — find these in Stripe dashboard > Products > [product] > Pricing
# These tell the webhook which plan a member subscribed to
STRIPE_GOLD_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PLATINUM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# URL members land on after closing the Stripe Customer Portal
STRIPE_PORTAL_RETURN_URL=https://homequarters.co.uk

# ─── Secrets (stored in Firebase Secret Manager, NOT this file) ───
# Run these commands to set them:
#
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#
# STRIPE_SECRET_KEY  → Stripe dashboard > Developers > API keys > Secret key (sk_live_... or sk_test_...)
# STRIPE_WEBHOOK_SECRET → Stripe dashboard > Developers > Webhooks > [your endpoint] > Signing secret (whsec_...)
#
# Webhook endpoint URL to register in Stripe:
#   https://us-central1-YOUR_FIREBASE_PROJECT_ID.cloudfunctions.net/stripeWebhook
#
# Stripe events to subscribe to:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed

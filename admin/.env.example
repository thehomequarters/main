VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# URL of the verifyRedemption Cloud Function (used by the /verify page to confirm redemptions).
# Format: https://{region}-{project-id}.cloudfunctions.net/verifyRedemption
# Find the exact URL in Firebase console → Functions after deploying.
VITE_VERIFY_FUNCTION_URL=https://us-central1-your-project-id.cloudfunctions.net/verifyRedemption

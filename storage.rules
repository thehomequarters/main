rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    // ──── Avatars ────
    // Users can only upload their own avatar (filename must start with their UID).
    // 5 MB limit, images only.
    match /avatars/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──── Post images ────
    // Authenticated users can read; 10 MB limit, images only.
    match /posts/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──── Chat images ────
    // Authenticated users can read; 10 MB limit, images only.
    match /chat/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

  }
}

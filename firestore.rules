rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requesting user owns this document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: check if user is an active member
    function isActiveMember() {
      return isAuth() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.membership_status == 'active';
    }

    // ──── Profiles ────
    match /profiles/{userId} {
      // Anyone authenticated can read profiles (for Discover tab)
      allow read: if isAuth();
      // Users can only create their own profile (during registration)
      allow create: if isOwner(userId);
      // Users can only update their own profile
      allow update: if isOwner(userId);
      // No one can delete profiles from the client
      allow delete: if false;
    }

    // ──── Venues ────
    match /venues/{venueId} {
      // Any authenticated user can read venues
      allow read: if isAuth();
      // Only allow writes from admin (server-side / seed function)
      // In production, restrict this to admin UIDs or use Cloud Functions
      allow write: if isAuth();
    }

    // ──── Deals ────
    match /deals/{dealId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ──── Events ────
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ──── Bookings ────
    match /bookings/{bookingId} {
      // Anyone authenticated can read (for attendee counts)
      allow read: if isAuth();
      // Only active members can create bookings, and only for themselves
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      // Members can only delete their own bookings
      allow delete: if isAuth() &&
        resource.data.member_id == request.auth.uid;
      allow update: if false;
    }

    // ──── Posts ────
    match /posts/{postId} {
      allow read: if isAuth();
      // Active members can create posts, must set their own author_id
      allow create: if isActiveMember() &&
        request.resource.data.author_id == request.auth.uid;
      // Allow updates for likes/comments count (any authenticated user)
      allow update: if isAuth();
      // Only the author can delete their own post
      allow delete: if isAuth() &&
        resource.data.author_id == request.auth.uid;
    }

    // ──── Comments ────
    match /comments/{commentId} {
      // Any authenticated user can read comments
      allow read: if isAuth();
      // Active members can create comments, must set their own author_id
      allow create: if isActiveMember() &&
        request.resource.data.author_id == request.auth.uid;
      // No editing or deleting comments from the client
      allow update, delete: if false;
    }

    // ──── Connections ────
    match /connections/{connectionId} {
      allow read: if isAuth();
      // Can only create connections from yourself
      allow create: if isActiveMember() &&
        request.resource.data.from_id == request.auth.uid;
      // Either party can update (accept/reject)
      allow update: if isAuth() && (
        resource.data.from_id == request.auth.uid ||
        resource.data.to_id == request.auth.uid
      );
      // Either party can delete
      allow delete: if isAuth() && (
        resource.data.from_id == request.auth.uid ||
        resource.data.to_id == request.auth.uid
      );
    }

    // ──── Groups ────
    match /groups/{groupId} {
      allow read: if isAuth();
      // Allow member count updates from authenticated users
      allow update: if isAuth();
      allow create: if isAuth();
      allow delete: if false;
    }

    // ──── Group Members ────
    match /group_members/{membershipId} {
      allow read: if isAuth();
      // Can only add yourself to a group
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      // Can only remove yourself
      allow delete: if isAuth() &&
        resource.data.member_id == request.auth.uid;
    }

    // ──── Redemptions ────
    match /redemptions/{redemptionId} {
      // Users can read their own redemptions
      allow read: if isAuth();
      // Active members can create redemptions for themselves
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ──── Conversations ────
    match /conversations/{conversationId} {
      // Only participants can read
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      // Authenticated users can create (checked in app logic)
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants;
      // Participants can update (last message, etc.)
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        // Only conversation participants can read messages
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // Only participants can send messages, must be from themselves
        allow create: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requesting user owns this document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: check if user is an admin (document exists in /admins collection)
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: check if user is an active member
    function isActiveMember() {
      return isAuth() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.membership_status == 'active';
    }

    // ──── Admins ────
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if false; // set via Firebase console or Cloud Functions only
    }

    // ──── Profiles ────
    match /profiles/{userId} {
      // Anyone authenticated can read profiles (for Discover tab)
      allow read: if isAuth();
      // Users can only create their own profile (during registration)
      allow create: if isOwner(userId);
      // Users can update their own profile; admins can update any profile (status changes)
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete profiles (soft or hard delete)
      allow delete: if isAdmin();
    }

    // ──── Invites ────
    match /invites/{inviteId} {
      // Anyone can get a specific invite by code to validate it (needed before auth)
      allow get: if true;
      // Admins can list all; active members can list their own sent invites
      allow list: if isAdmin() || isActiveMember();
      // Admins OR active members can create invites (member nominations)
      allow create: if isAdmin() || (isActiveMember() && request.resource.data.created_by == request.auth.uid);
      allow delete: if isAdmin();
      // Admins or the newly authenticated user can mark an invite as used
      allow update: if isAdmin() || (isAuth() && !resource.data.used);
    }

    // ──── Venues ────
    match /venues/{venueId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ──── Deals ────
    match /deals/{dealId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ──── Venue Stories ────
    match /venue_stories/{storyId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ──── Onboarding Slides ────
    // Public read: shown before login, no sensitive data
    match /onboarding_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──── Events ────
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ──── Bookings ────
    match /bookings/{bookingId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.member_id == request.auth.uid;
      allow update: if false;
    }

    // ──── Posts ────
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.author_id == request.auth.uid;
      // Only the post author (for likes/comments count) or an admin (hide/moderate) can update
      allow update: if (isAuth() && resource.data.author_id == request.auth.uid) || isAdmin();
      // Author or admin can delete
      allow delete: if (isAuth() && resource.data.author_id == request.auth.uid) || isAdmin();
    }

    // ──── Comments ────
    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.author_id == request.auth.uid;
      allow update: if false;
      // Author or admin can delete; explicit parentheses for operator precedence
      allow delete: if (isAuth() && resource.data.author_id == request.auth.uid) || isAdmin();
    }

    // ──── Connections ────
    match /connections/{connectionId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.from_id == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.from_id == request.auth.uid ||
        resource.data.to_id == request.auth.uid
      );
      allow delete: if isAuth() && (
        resource.data.from_id == request.auth.uid ||
        resource.data.to_id == request.auth.uid
      );
    }

    // ──── Groups ────
    match /groups/{groupId} {
      allow read: if isAuth();
      // Creator must set themselves as creator_id; only creator or admin can update
      allow create: if isActiveMember() &&
        request.resource.data.creator_id == request.auth.uid;
      allow update: if (isAuth() && resource.data.creator_id == request.auth.uid) || isAdmin();
      allow delete: if (isAuth() && resource.data.creator_id == request.auth.uid) || isAdmin();
    }

    // ──── Group Members ────
    match /group_members/{membershipId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.member_id == request.auth.uid;
    }

    // ──── Group Messages ────
    match /group_messages/{messageId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.author_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ──── Redemptions ────
    match /redemptions/{redemptionId} {
      allow read: if isAuth();
      allow create: if isActiveMember() &&
        request.resource.data.member_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ──── Conversations ────
    match /conversations/{conversationId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
